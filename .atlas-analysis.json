  "keyFeatures": [
    "Visual drag-and-drop designer for building UIs without code",
    "Component-based architecture with 40+ pre-built UI components",
    "Full-stack framework with server-side rendering and client-side routing",
    "Database ORM integration with Sequelize supporting MySQL, MariaDB, and SQLite",
    "Extensible module system for creating custom applications",
    "CLI tools for project management and deployment",
    "Built-in authentication and session management",
    "Theme customization with Tailwind CSS integration",
    "File management and media handling",
    "Multi-tenant architecture support"
  ],
  "publicApiSurface": [
    "loopar - Core framework instance",
    "BaseDocument - Base class for data models",
    "BaseController - Base class for controllers",
    "SingleController - Controller for single record views",
    "PageController - Controller for static pages",
    "FormController - Controller for forms",
    "ViewController - Controller for list views",
    "ReportController - Controller for reports",
    "documentManage - Document management utilities",
    "fileManage - File management utilities",
    "Helpers - Utility functions",
    "elementsDict - Component definitions",
    "MetaComponents - Component metadata",
    "themes - Theme definitions",
    "generateThemeCSS - Theme CSS generator"
  ]
}
